<div class="min-h-screen flex flex-col items-center justify-center px-4">
  <div class="w-full max-w-sm flex flex-col items-center gap-8">
    <div class="flex flex-col items-center gap-2">
      <div class="flex items-center gap-2">
        <span class="inline-block w-0.5 h-5 rounded-full bg-indigo-500"></span>
        <span class="text-xl font-semibold tracking-tight text-base-content">Sancha</span>
      </div>
      <p class="text-sm text-base-content/40">Sign in to continue</p>
    </div>

    <div class="w-full bg-base-100 border border-base-200 rounded-2xl p-8 flex flex-col gap-5">
      <a
        href="/auth/hackclub"
        class="flex items-center justify-center gap-2.5 w-full py-2.5 px-4 rounded-xl font-medium text-sm text-white transition-opacity hover:opacity-85 active:opacity-70"
        style="background-color: #ec3750;"
      >
        <span class="flex items-center gap-2.5">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="white" aria-hidden="true">
            <path d="M5 3h4v7h6V3h4v18h-4v-7H9v7H5V3z" />
          </svg>
          Continue with Hack Club
        </span>
      </a>

      <div class="flex items-center gap-3">
        <div class="flex-1 h-px bg-base-200"></div>
        <span class="text-xs text-base-content/30 uppercase tracking-widest">or</span>
        <div class="flex-1 h-px bg-base-200"></div>
      </div>

      <div class="bg-base-200/60 rounded-xl px-3.5 py-3 flex gap-2.5 items-start">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-4 w-4 text-base-content/40 mt-0.5 shrink-0"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M13 16h-1v-4h-1m1-4h.01M12 2a10 10 0 110 20A10 10 0 0112 2z"
          />
        </svg>
        <p class="text-xs text-base-content/50 leading-relaxed">
          Sancha uses Hack Club Auth for sign-in. You'll need a Hack Club account to continue. No password required.
        </p>
      </div>
    </div>

    <p class="text-xs text-base-content/30 text-center leading-relaxed">
      By continuing, you agree to Sancha's
      <a
        href="/terms"
        class="underline underline-offset-2 hover:text-base-content/50 transition-colors"
      >
        terms
      </a>
      and <a
        href="/privacy"
        class="underline underline-offset-2 hover:text-base-content/50 transition-colors"
      >privacy policy</a>.
    </p>
  </div>
</div>
